# Wallet private key (required) — used to derive API credentials automatically
PRIVATE_KEY=your_wallet_private_key_here

# Polymarket API credentials (optional — auto-derived from PRIVATE_KEY on first run)
# Copy the values printed on first run to skip re-derivation each startup.
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Trading environment: "production" or "staging"
POLY_HOST=https://clob.polymarket.com
CHAIN_ID=137

# Risk management
MAX_POSITION_SIZE_USD=100.0
MAX_TOTAL_EXPOSURE_USD=500.0
MAX_LOSS_PER_TRADE_PCT=0.05
DAILY_LOSS_LIMIT_USD=200.0

# Strategy selection: macd | rsi | cvd
ACTIVE_STRATEGY=rsi

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
