# Polymarket API credentials
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_passphrase_here
POLY_PRIVATE_KEY=your_wallet_private_key_here

# Trading environment: "production" or "staging"
POLY_HOST=https://clob.polymarket.com
CHAIN_ID=137

# Risk management
MAX_POSITION_SIZE_USD=100.0
MAX_TOTAL_EXPOSURE_USD=500.0
MAX_LOSS_PER_TRADE_PCT=0.05
DAILY_LOSS_LIMIT_USD=200.0

# Strategy selection: macd | rsi | cvd
ACTIVE_STRATEGY=rsi

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
